{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "typeRoots": ["./api/node_modules/@types"],
    "types": ["node", "jest"]
  },
  "include": ["api/src/**/*", "api/tsconfig.spec.json"],
  "exclude": ["node_modules", "api/dist"]
}
