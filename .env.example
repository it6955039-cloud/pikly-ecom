# ═══════════════════════════════════════════════════════════════════
# PIKLY  —  Environment Variables  v5.0.0
# Copy to .env and fill in your values before running.
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL (Neon) ────────────────────────────────────────────
# Get from: neon.tech → project settings → connection string
# MUST include ?sslmode=require at the end
DATABASE_URL=

# ── Redis (Upstash) ──────────────────────────────────────────────
# Get from: upstash.com → Redis database → REST API section
# Use rediss:// (double-s) for TLS — required by Upstash
REDIS_URL=

# ── Auth ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
# ── Algolia Search ───────────────────────────────────────────────
# Get from: algolia.com → Settings → API Keys
ALGOLIA_APP_ID=
# Admin API Key — write operations only (index config, product sync).
# NEVER used for end-user search queries.
ALGOLIA_WRITE_KEY=
# Search-Only API Key — read-only, safe to use for all search requests.
# Get from: algolia.com → Settings → API Keys → Search-Only API Key
ALGOLIA_SEARCH_KEY=
ALGOLIA_INDEX=

# ── Gemini AI (for CIL accordion + facet generation) ─────────────
# Get from: aistudio.google.com/app/apikey  — FREE
# Without this key, CIL uses rule-based grouping only (still works)
GEMINI_API_KEY=

# ── Cloudinary (image uploads) ───────────────────────────────────
# Get from: cloudinary.com → Dashboard
# Images are stored on Cloudinary (NOT local disk) so uploads survive
# Railway deploys, restarts, and horizontal scaling.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: override the Cloudinary folder for uploads (default: pikly/uploads)
CLOUDINARY_UPLOAD_FOLDER=pikly/uploads

# ── Email (optional) ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# ── App Config ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FREE_SHIPPING_THRESHOLD=50
FLAT_SHIPPING_COST=9.99
TAX_RATE=0.10

# ── Additional Auth ───────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=

# ── Developer Tools ───────────────────────────────────────────────────────────
# Set to 'true' to enable Swagger UI at /api/docs
SWAGGER_ENABLED=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
